---
import Layout from '@/layouts/Layout.astro';
import CTAButton from '@/components/CTAButton.astro';
import { site } from '@/data/site';
---

<Layout
  title="Blog - Conteúdo sobre Batatas Artesanais e Negócios"
  description="Dicas para revendedores, tendências de mercado, bastidores da produção e mais. Conteúdo Ahara que agrega valor ao seu negócio."
>

  <!-- ━━ HERO ━━ -->
  <section class="bg-brand-orange border-b-[3px] border-black py-20 md:py-24 overflow-hidden relative">
    <div class="absolute -right-10 top-10 w-64 h-64 bg-brand-yellow/20 rounded-full pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <span class="inline-block bg-brand-yellow border-2 border-black px-3 py-1 text-xs font-impact shadow-brutal mb-6 rounded-full">
        BLOG
      </span>
      <h1 class="font-display font-bold text-5xl md:text-6xl text-white mb-5 leading-[1.05]">
        Conteúdo sobre<br/><span class="text-brand-yellow">Batatas Artesanais</span><br/>e Negócios
      </h1>
      <p class="font-body text-xl text-white/80 max-w-2xl leading-relaxed">
        Dicas para revendedores, tendências de mercado, bastidores da produção e mais.
        Conteúdo que agrega valor ao seu negócio.
      </p>
    </div>
  </section>

  <!-- ━━ CATEGORIAS ━━ -->
  <section class="bg-linen border-b-[3px] border-black py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-black mb-3">Explore por categoria</h2>
        <p class="font-body text-lg text-black/60">Em breve, novos artigos para te ajudar a crescer.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-12">
        {[
          {
            icon: '🏭',
            title: 'Produção Artesanal',
            desc: 'Bastidores da produção, curiosidades sobre batatas, processo artesanal. Como fazemos nossas chips do jeito certo.',
            href: '/blog/producao-artesanal/',
            color: 'bg-brand-yellow',
            posts: 'Em breve',
          },
          {
            icon: '📊',
            title: 'Dicas para Negócios',
            desc: 'Conteúdo para revendedores e comerciantes: margem de lucro, estratégias de vendas, gestão de estoque.',
            href: '/blog/negocios/',
            color: 'bg-brand-purple',
            posts: 'Em breve',
          },
          {
            icon: '🎉',
            title: 'Eventos & Food Service',
            desc: 'Tendências, dicas de apresentação, cases de sucesso. Como usar batatas artesanais para elevar seu serviço.',
            href: '/blog/eventos/',
            color: 'bg-brand-green',
            posts: 'Em breve',
          },
        ].map(cat => (
          <article class={`border-[3px] border-black shadow-brutal flex flex-col rounded-3xl overflow-hidden ${cat.color}`}>
            <div class="p-6 flex-1">
              <div class="text-4xl mb-4">{cat.icon}</div>
              <h3 class="font-display font-bold text-2xl text-white mb-3 leading-tight">{cat.title}</h3>
              <p class="font-body text-sm text-white/80 mb-4 leading-relaxed">{cat.desc}</p>
              <span class="inline-block border border-white/40 text-white/60 text-xs font-body px-3 py-1 rounded-full">
                {cat.posts}
              </span>
            </div>
            <div class="px-6 pb-6">
              <span class="btn-base bg-black/40 text-linen text-sm w-full justify-center cursor-not-allowed">
                Em breve
              </span>
            </div>
          </article>
        ))}
      </div>

      <!-- Aviso -->
      <div class="card-brutal bg-white p-8 text-center max-w-xl mx-auto">
        <div class="text-5xl mb-4">📬</div>
        <h3 class="font-display font-bold text-2xl mb-3">Blog em construção</h3>
        <p class="font-body text-black/60 mb-6">
          Estamos preparando conteúdo de qualidade para você.
          Enquanto isso, fale com a Ahara pelo WhatsApp para novidades.
        </p>
        <CTAButton
          href={site.whatsapp.url}
          label="Falar com a Ahara"
          variant="purple"
          icon="whatsapp"
          external={true}
        />
      </div>
    </div>
  </section>

</Layout>
