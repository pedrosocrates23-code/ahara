---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import CTAButton from '@/components/CTAButton.astro';
import { site } from '@/data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pub_date.getTime() - a.data.pub_date.getTime());

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site.url}/blog/` },
  ],
};

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog Ahara',
  url: `${site.url}/blog/`,
  publisher: { '@id': `${site.url}/#organization` },
  inLanguage: 'pt-BR',
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.h1,
    url: `${site.url}/blog/${p.id}/`,
    description: p.data.meta_description,
    wordCount: p.data.palavras_totais,
    datePublished: p.data.pub_date.toISOString(),
  })),
};

const colors = ['bg-brand-red', 'bg-brand-purple', 'bg-brand-green', 'bg-brand-yellow', 'bg-brand-orange', 'bg-brand-pink'];
---

<Layout
  title="Blog Ahara - Atacado e Revenda de Batata Chips"
  description="Guias práticos para revendedores, comércios e eventos. Onde comprar batata chips no DF, tabelas de margem, logística e muito mais. Blog da Ahara."
  extraSchemas={[breadcrumbSchema, blogSchema]}
>

  <!-- ━━ HERO ━━ -->
  <section class="bg-brand-orange border-b-[3px] border-black py-20 md:py-24 overflow-hidden relative">
    <div class="absolute -right-10 top-10 w-64 h-64 bg-brand-yellow/20 blob-organic pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4">
      <span class="inline-block bg-brand-yellow border-2 border-black px-3 py-1 text-xs font-impact shadow-brutal mb-6 rounded-full">
        BLOG AHARA
      </span>
      <h1 class="font-display font-bold text-5xl md:text-6xl text-white mb-5 leading-[1.05]">
        Guias para <span class="text-brand-yellow">Revenda</span><br/>e Atacado no DF
      </h1>
      <p class="font-body text-xl text-white/95 max-w-2xl leading-relaxed">
        Tabelas de margem, logística local, critérios de fornecedor e dicas práticas
        para revendedores, comércios e eventos. Conteúdo objetivo, sem enrolação.
      </p>
    </div>
  </section>

  <!-- ━━ LISTA DE POSTS ━━ -->
  <section class="bg-linen border-b-[3px] border-black py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-black mb-8">
        {posts.length} artigos publicados
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((p, i) => {
          const color = colors[i % colors.length];
          const textIsDark = color === 'bg-brand-yellow';
          return (
            <a
              href={`/blog/${p.id}/`}
              class={`border-[3px] border-black shadow-brutal rounded-3xl p-6 flex flex-col gap-3 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-brutal-lg transition-all ${color}`}
            >
              <span class={`inline-block border-2 border-black px-3 py-0.5 text-xs font-impact w-fit rounded-full ${textIsDark ? 'bg-black text-linen' : 'bg-white text-black'}`}>
                #{String(i + 1).padStart(2, '0')}
              </span>
              <h3 class={`font-display font-bold text-xl leading-tight ${textIsDark ? 'text-black' : 'text-white'}`}>
                {p.data.h1}
              </h3>
              <p class={`font-body text-sm leading-snug flex-1 ${textIsDark ? 'text-black/80' : 'text-white/95'}`}>
                {p.data.meta_description}
              </p>
              <span class={`text-xs font-body font-bold mt-2 ${textIsDark ? 'text-black' : 'text-white'}`}>
                Ler artigo · {Math.ceil(p.data.palavras_totais / 220)} min →
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ━━ CTA FINAL ━━ -->
  <section class="bg-brand-purple py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-display font-bold text-3xl text-white mb-2">Quer revender ou comprar em atacado?</h2>
        <p class="font-body text-white/95">Pedido mínimo 5kg. Atendimento direto pelo WhatsApp.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <CTAButton
          href={site.whatsapp.url}
          label="Falar com a Ahara"
          variant="green"
          icon="whatsapp"
          external={true}
        />
        <CTAButton href="/contato/" label="Formulário" variant="yellow" />
      </div>
    </div>
  </section>

</Layout>
