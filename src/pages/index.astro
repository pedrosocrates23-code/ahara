---
import Layout from '@/layouts/Layout.astro';
import CTAButton from '@/components/CTAButton.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import AudienceCard from '@/components/AudienceCard.astro';
import { Picture } from 'astro:assets';
import heroChipsImg from '@/assets/images/hero-chips.webp';
import { site, img } from '@/data/site';

const waHero = site.whatsapp.link('Olá, gostaria de fazer um pedido de batatas chips Ahara');

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site.url}/#brand`,
  name: site.legalName,
  alternateName: site.name,
  url: site.url,
  logo: `${site.url}/logo.png`,
  foundingLocation: {
    '@type': 'Place',
    name: 'Brasília, DF, Brasil',
  },
  knowsAbout: ['Batatas chips artesanais', 'Food service', 'Distribuição B2B'],
};
---

<Layout
  title="Batatas Chips Artesanais em Brasília/DF"
  description="Distribuidora B2B de batatas chips artesanais em Brasília/DF. Revendedores, comércios, eventos e food service. Pedido mínimo 5kg."
  preloadImage={img.heroChips}
  extraSchemas={[organizationSchema]}
>

  <!-- ━━ HERO ━━ -->
  <section class="relative overflow-hidden bg-linen border-b-[3px] border-black">
    <!-- Decorative blobs -->
    <div class="absolute top-0 right-0 w-72 h-72 bg-brand-purple/10 rounded-full -translate-y-1/3 translate-x-1/4 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-brand-yellow/20 rounded-full translate-y-1/3 -translate-x-1/4 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-1/2 right-1/4 w-24 h-24 bg-brand-red/10 rounded-full pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
      <div class="flex flex-col gap-6">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 w-fit">
          <span class="bg-brand-yellow border-2 border-black px-3 py-1 text-xs font-impact font-bold tracking-wider shadow-brutal rounded-full">
            🏭 PRODUÇÃO LOCAL · BRASÍLIA/DF
          </span>
        </div>

        <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] text-black">
          Batatas Chips<br/>
          <span class="text-brand-purple">Artesanais</span><br/>
          para seu Negócio
        </h1>

        <p class="font-body text-lg text-black/70 max-w-md leading-relaxed">
          Qualidade artesanal, preço justo e entrega rápida.
          Do DF para o DF - atendemos revendedores, comércios, restaurantes e eventos.
        </p>

        <div class="flex flex-wrap gap-3">
          <CTAButton href="/para-revendedores/" label="Seja Revendedor" variant="purple" size="lg" icon="arrow" />
          <CTAButton href="/produtos/" label="Ver Produtos" variant="yellow" size="lg" icon="arrow" />
        </div>
      </div>

      <!-- Hero visual -->
      <div class="flex justify-center items-center">
        <div class="relative w-full max-w-sm md:max-w-md">
          <Picture
            src={heroChipsImg}
            alt="Batatas chips artesanais em uma tigela sobre fundo rústico"
            widths={[300, 400, 500, 600]}
            formats={['avif', 'webp']}
            sizes="(max-width: 640px) calc(100vw - 2rem), (max-width: 768px) 384px, 448px"
            loading="eager"
            fetchpriority="high"
            class="w-full aspect-square object-cover border-[3px] border-black shadow-brutal-lg bg-white rounded-3xl"
          />
          <!-- Decorative stickers -->
          <div class="absolute -top-3 -right-3 md:-top-4 md:-right-4 bg-brand-red text-white border-2 border-black shadow-brutal px-3 py-1 font-impact text-xs md:text-sm rotate-6 rounded-full">
            ARTESANAL
          </div>
          <div class="absolute -bottom-3 -left-3 md:-bottom-4 md:-left-4 bg-brand-yellow border-2 border-black shadow-brutal px-3 py-1 font-impact text-xs md:text-sm -rotate-3 rounded-full">
            PRODUÇÃO LOCAL
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ━━ STATS BAR ━━ -->
  <section class="bg-black border-b-[3px] border-black" aria-label="Destaques">
    <div class="max-w-6xl mx-auto px-4 py-5 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-0 md:divide-x md:divide-linen/20">
      {[
        ['5kg', 'Pedido mínimo'],
        ['3 tamanhos', '50g · 150g · 500g'],
        ['Até 12%', 'Desconto progressivo'],
        ['Entrega 15kg+', '5 regiões do DF'],
      ].map(([value, label]) => (
        <div class="flex flex-col items-center text-center px-4 py-2">
          <span class="font-display font-bold text-2xl text-brand-yellow">{value}</span>
          <span class="font-body text-xs text-linen/95 mt-0.5">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ━━ POR QUE ESCOLHER ━━ -->
  <section class="bg-linen py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-black mb-3">
          Por que escolher a <span class="text-brand-purple">Ahara?</span>
        </h2>
        <p class="font-body text-lg text-black/60 max-w-xl">
          Qualidade artesanal com a agilidade de um fornecedor local.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <FeatureCard
          icon="🌿"
          title="Produção Local no DF"
          description="Produto fresco, entrega rápida, reposição ágil. Sem depender de transporte de outros estados."
          accentColor="bg-brand-green"
        />
        <FeatureCard
          icon="💰"
          title="Preço Transparente"
          description="Tabela de preços clara com desconto progressivo de 5% a 12% conforme o volume."
          accentColor="bg-brand-yellow"
        />
        <FeatureCard
          icon="🥔"
          title="Matéria-prima Selecionada"
          description="Batatas Marquise e Atlantic, as melhores variedades para fritura: crocância superior e sabor marcante."
          accentColor="bg-brand-red"
        />
        <FeatureCard
          icon="🤝"
          title="Atendimento Próximo"
          description="Conhecemos nossos clientes e entendemos a realidade de cada negócio. Suporte pelo WhatsApp."
          accentColor="bg-brand-purple"
        />
      </div>
    </div>
  </section>

  <!-- ━━ PARA QUEM ━━ -->
  <section class="bg-brand-purple border-y-[3px] border-black py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-white mb-3">
          Para quem é a Ahara?
        </h2>
        <p class="font-body text-lg text-white/90 max-w-xl">
          Atendemos diferentes perfis de negócio que buscam um fornecedor local confiável.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <AudienceCard
          emoji="🛒"
          title="Revendedores Autônomos"
          description="Trabalha em praças, órgãos, escolas ou na rua? Embalagens de 50g e 150g perfeitas para revenda com boa margem."
          ctaLabel="Condições para Revendedores"
          ctaHref="/para-revendedores/"
          bgColor="bg-brand-red"
        />
        <AudienceCard
          emoji="🏪"
          title="Comércios"
          description="Mercados, empórios, conveniências e quiosques. Produto artesanal que se destaca na prateleira e fideliza clientes."
          ctaLabel="Condições para Comércios"
          ctaHref="/para-comercios/"
          bgColor="bg-brand-yellow"
          textColor="text-black"
        />
        <AudienceCard
          emoji="🎉"
          title="Eventos & Food Service"
          description="Buffets, bares, restaurantes e casas de festa. Produção local significa agilidade para atender urgências."
          ctaLabel="Condições para Eventos"
          ctaHref="/para-eventos/"
          bgColor="bg-brand-green"
        />
      </div>
    </div>
  </section>

  <!-- ━━ COMO FUNCIONA ━━ -->
  <section class="bg-linen py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-black mb-3">
          Como funciona?
        </h2>
        <p class="font-body text-lg text-black/60">
          Processo simples, preços transparentes, sem surpresas.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          { step: '01', title: 'Pedido mínimo de 5kg', desc: 'Começamos a atender a partir de 5kg (~R$275). Acessível para testar o produto ou para negócios menores.', color: 'bg-brand-yellow' },
          { step: '02', title: 'Desconto progressivo', desc: 'Quanto mais você compra, menos paga. Descontos de 5% a 12% conforme o volume do pedido, pagamento à vista.', color: 'bg-brand-purple' },
          { step: '03', title: 'Retirada ou entrega', desc: 'Pedidos até 14kg: retirada em nosso endereço. A partir de 15kg: entrega nas regiões atendidas do DF.', color: 'bg-brand-green' },
        ].map(item => (
          <div class="card-brutal bg-white p-6 flex flex-col gap-4 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-brutal-lg transition-all">
            <div class={`w-14 h-14 border-2 border-black flex items-center justify-center shadow-brutal font-impact font-bold text-xl text-black rounded-2xl ${item.color}`}>
              {item.step}
            </div>
            <h3 class="font-display font-bold text-xl">{item.title}</h3>
            <p class="font-body text-sm text-black/70 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ━━ PRODUTO ━━ -->
  <section class="bg-black border-y-[3px] border-black py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-linen mb-3">
          Nosso <span class="text-brand-yellow">Produto</span>
        </h2>
        <p class="font-body text-lg text-linen/95 max-w-xl">
          Batatas chips artesanais sabor tradicional em três tamanhos.
          Matéria-prima selecionada, produção local.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-10">
        {[
          { size: '50g', label: 'Porção Individual', desc: 'Ideal para revendedores autônomos, cantinas e conveniências. 20 unidades por kg.', color: 'bg-brand-red' },
          { size: '150g', label: 'Porção Média', desc: 'Perfeito para mercados, empórios, bares e restaurantes. Cerca de 6,6 unidades por kg.', color: 'bg-brand-purple' },
          { size: '500g', label: 'Food Service', desc: 'Para buffets, eventos e alto volume. Facilita porcionamento e controle. 2 unidades por kg.', color: 'bg-brand-green' },
        ].map(pkg => (
          <div class={`border-[3px] border-black shadow-brutal flex flex-col rounded-3xl p-6 gap-3 ${pkg.color}`}>
            <div class="bg-black text-linen border-2 border-black w-fit px-4 py-1 font-impact font-bold text-2xl shadow-brutal-yellow rounded-full">
              {pkg.size}
            </div>
            <h3 class="font-display font-bold text-xl text-white">{pkg.label}</h3>
            <p class="font-body text-sm text-white/95 leading-relaxed">{pkg.desc}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-3">
        <CTAButton href="/produtos/" label="Ver todos os produtos" variant="yellow" icon="arrow" />
        <CTAButton href="/contato/" label="Fazer pedido" variant="black" icon="arrow" />
      </div>
    </div>
  </section>

  <!-- ━━ CTA FINAL ━━ -->
  <section class="bg-brand-red border-b-[3px] border-black py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-white mb-2">
          Pronto para começar?
        </h2>
        <p class="font-body text-white/95 text-lg">
          Pedido mínimo de 5kg. Atendimento rápido pelo WhatsApp.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 flex-shrink-0">
        <CTAButton
          href={waHero}
          label="Chamar no WhatsApp"
          variant="green"
          size="lg"
          external={true}
          icon="whatsapp"
        />
        <CTAButton href="/contato/" label="Ver mais opções" variant="yellow" size="lg" />
      </div>
    </div>
  </section>

</Layout>
