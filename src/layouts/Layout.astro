---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { ClientRouter } from 'astro:transitions';
import { site } from '@/data/site';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  preloadImage?: string;
  /**
   * Schemas adicionais para a página (Product, FAQPage, BreadcrumbList, etc).
   * São injetados como JSON-LD separados.
   */
  extraSchemas?: Record<string, unknown>[];
}

const {
  title,
  description = 'Distribuidora B2B de batatas chips artesanais produzidas localmente em Brasília/DF. Atendemos revendedores, comércios, eventos e food service.',
  ogImage = '/images/hero-chips.webp',
  preloadImage,
  extraSchemas = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Ahara`;
const absoluteOgImage = new URL(ogImage, Astro.site).toString();

// Schema LocalBusiness / FoodEstablishment principal (presente em todas as páginas)
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'FoodEstablishment',
  '@id': `${site.url}/#organization`,
  name: site.legalName,
  alternateName: site.name,
  description: 'Distribuidora B2B de batatas chips artesanais em Brasília/DF. Produção local, atendimento para revendedores, comércios, eventos e food service.',
  url: site.url,
  logo: new URL('/logo.png', site.url).toString(),
  image: new URL('/logo.png', site.url).toString(),
  telephone: `+${site.whatsapp.number}`,
  priceRange: 'R$ 48 a R$ 55 por kg',
  servesCuisine: 'Snacks artesanais',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: 'Brasília',
    addressRegion: 'DF',
    addressCountry: 'BR',
  },
  email: site.email,
  areaServed: site.regions.map((region) => ({
    '@type': 'City',
    name: region,
  })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '08:00',
      closes: '12:00',
    },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: `+${site.whatsapp.number}`,
    contactType: 'sales',
    areaServed: 'BR',
    availableLanguage: 'Portuguese',
  },
  sameAs: [],
};

// WebSite schema (ajuda o Google a entender a navegação e sitelinks)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  url: site.url,
  name: site.name,
  description: 'Batatas chips artesanais em Brasília/DF',
  inLanguage: 'pt-BR',
  publisher: {
    '@id': `${site.url}/#organization`,
  },
};
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#6654ca" />
    <meta name="author" content={site.legalName} />
    <meta name="geo.region" content="BR-DF" />
    <meta name="geo.placename" content="Brasília" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="600" />
    <meta property="og:image:height" content="600" />
    <meta property="og:image:alt" content={`${site.name} - ${title}`} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={site.legalName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {extraSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Preconnect + Preload de recursos críticos -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Google Fonts (substitutos até as fontes oficiais chegarem) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&family=Dancing+Script:wght@700&family=Anton&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&family=Dancing+Script:wght@700&family=Anton&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-P7MVJ8Q12H"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-P7MVJ8Q12H', { send_page_view: false });
    </script>
    <ClientRouter />
  </head>
  <body>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <!-- Dispara page_view no carregamento inicial e em cada navegação via View Transitions -->
    <script>
      document.addEventListener('astro:page-load', () => {
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'page_view', {
            page_title: document.title,
            page_location: window.location.href,
          });
        }
      });
    </script>
  </body>
</html>
