---
interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  bgColor: string;
  textColor?: string;
  emoji: string;
}
const {
  title,
  description,
  ctaLabel,
  ctaHref,
  bgColor,
  textColor = 'text-white',
  emoji,
} = Astro.props;
---
<div class={`border-[3px] border-black shadow-brutal flex flex-col rounded-3xl overflow-hidden ${bgColor}`}>
  <div class="p-6 flex flex-col gap-3 flex-1">
    <div class="text-4xl" aria-hidden="true">{emoji}</div>
    <h3 class={`font-display font-bold text-2xl leading-tight ${textColor}`}>{title}</h3>
    <p class={`font-body text-sm leading-relaxed flex-1 ${textColor} opacity-90`}>{description}</p>
  </div>
  <div class="px-6 pb-6">
    <a
      href={ctaHref}
      class="btn-base bg-black text-linen text-sm hover:btn-hover w-full justify-center"
    >
      {ctaLabel} →
    </a>
  </div>
</div>
