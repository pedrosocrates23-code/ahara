---
import { site } from '@/data/site';

const whatsUrl = site.whatsapp.link('Olá, gostaria de saber mais sobre as batatas chips Ahara');

const links = [
  { label: 'Início',   href: '/' },
  { label: 'Sobre',    href: '/sobre/' },
  { label: 'Produtos', href: '/produtos/' },
];

const b2bLinks = [
  { label: 'Para Revendedores', href: '/para-revendedores/' },
  { label: 'Para Comércios',    href: '/para-comercios/' },
  { label: 'Para Eventos',      href: '/para-eventos/' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 bg-linen border-b-[3px] border-black">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex-shrink-0 flex items-center" aria-label="Ahara - página inicial">
      <img src="/logo.webp" alt="Ahara" width="140" height="66" class="h-9 w-auto" loading="eager" fetchpriority="high" decoding="async" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Navegação principal">
      {links.map(link => (
        <a
          href={link.href}
          class={`px-3 py-1.5 font-body font-medium text-sm transition-colors rounded-full hover:bg-brand-purple/10 ${isActive(link.href) ? 'text-brand-purple font-bold' : ''}`}
        >
          {link.label}
        </a>
      ))}

      <!-- Para Negócios dropdown (CSS-only com hover-bridge) -->
      <div class="relative group">
        <button
          class="flex items-center gap-1 px-3 py-1.5 font-body font-medium text-sm hover:bg-brand-purple/10 rounded-full transition-colors cursor-pointer"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Para Negócios
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="currentColor">
            <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown-menu absolute top-full left-0 w-56 hidden group-hover:flex flex-col">
          <div class="bg-linen border-[2px] border-black shadow-brutal rounded-2xl overflow-hidden flex flex-col">
            {b2bLinks.map((link, i) => (
              <a
                href={link.href}
                class={`px-4 py-3 font-body text-sm font-medium hover:bg-brand-purple hover:text-white transition-colors ${i !== b2bLinks.length - 1 ? 'border-b border-black/15' : ''} ${isActive(link.href) ? 'bg-brand-purple/10 text-brand-purple font-bold' : ''}`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <!-- WhatsApp CTA -->
    <a
      href={whatsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 btn-base bg-brand-green text-white text-sm px-4 py-2 hover:btn-hover rounded-full"
    >
      <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.12 1.535 5.856L0 24l6.336-1.511A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.822 9.822 0 01-5.003-1.366l-.36-.213-3.757.984 1.003-3.655-.234-.376A9.825 9.825 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.429 0 9.818 4.388 9.818 9.818 0 5.429-4.389 9.818-9.818 9.818z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Mobile hamburger (CSS-only via <details>) -->
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 border-2 border-black bg-white shadow-brutal hover:btn-hover transition-all rounded-xl" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </summary>
      <div class="absolute top-full right-0 mt-2 w-64 bg-linen border-[2px] border-black shadow-brutal-lg flex flex-col rounded-2xl overflow-hidden">
        {[...links, ...b2bLinks].map((link, i, arr) => (
          <a
            href={link.href}
            class={`px-5 py-3.5 font-body font-medium text-sm hover:bg-brand-purple hover:text-white transition-colors ${i !== arr.length - 1 ? 'border-b border-black/15' : ''} ${isActive(link.href) ? 'text-brand-purple font-bold' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contato/"
          class="px-5 py-3.5 font-body font-bold text-sm bg-brand-green text-white hover:bg-brand-green/90 transition-colors border-t-2 border-black"
        >
          Contato / WhatsApp
        </a>
      </div>
    </details>

  </div>
</header>
