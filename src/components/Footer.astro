---
import { site } from '@/data/site';
const year = new Date().getFullYear();
const whatsUrl = site.whatsapp.url;
---
<footer class="bg-black text-linen">
  <div class="max-w-6xl mx-auto px-4 py-16 grid grid-cols-2 md:grid-cols-4 gap-8">

    <!-- Brand -->
    <div class="col-span-2 md:col-span-1">
      <img src="/logo.webp" alt="Ahara" width="140" height="66" class="h-10 w-auto mb-4 brightness-0 invert" loading="lazy" decoding="async" />
      <p class="text-sm text-linen/90 leading-relaxed">
        Batatas chips artesanais com produção local em Brasília/DF.
        Qualidade artesanal, preço justo, entrega rápida.
      </p>
      <a
        href={whatsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 btn-base bg-brand-green text-white text-sm px-4 py-2 hover:btn-hover"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.12 1.535 5.856L0 24l6.336-1.511A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.822 9.822 0 01-5.003-1.366l-.36-.213-3.757.984 1.003-3.655-.234-.376A9.825 9.825 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.429 0 9.818 4.388 9.818 9.818 0 5.429-4.389 9.818-9.818 9.818z"/>
        </svg>
        Falar no WhatsApp
      </a>
    </div>

    <!-- Páginas -->
    <div>
      <h3 class="font-display font-bold text-base mb-4">Páginas</h3>
      <ul class="space-y-2 text-sm text-linen/90">
        {[
          ['Início', '/'],
          ['Sobre', '/sobre/'],
          ['Produtos', '/produtos/'],
          ['Blog', '/blog/'],
          ['Contato', '/contato/'],
        ].map(([label, href]) => (
          <li><a href={href} class="hover:text-linen transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Para negócios -->
    <div>
      <h3 class="font-display font-bold text-base mb-4">Para seu negócio</h3>
      <ul class="space-y-2 text-sm text-linen/90">
        {[
          ['Revendedores', '/para-revendedores/'],
          ['Comércios', '/para-comercios/'],
          ['Eventos & Food Service', '/para-eventos/'],
        ].map(([label, href]) => (
          <li><a href={href} class="hover:text-linen transition-colors">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contato -->
    <div>
      <h3 class="font-display font-bold text-base mb-4">Contato</h3>
      <ul class="space-y-2 text-sm text-linen/90">
        <li>
          <a href={site.whatsapp.url} target="_blank" rel="noopener noreferrer" class="hover:text-linen transition-colors">
            {site.whatsapp.display}
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-linen transition-colors">
            {site.email}
          </a>
        </li>
        <li>{site.hours.weekdays}</li>
        <li>{site.hours.saturday}</li>
        <li class="pt-2 text-linen/75 text-xs leading-snug">
          {site.regions.join(' · ')}
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-linen/10 py-5 px-4">
    <div class="max-w-6xl mx-auto flex flex-col gap-3 text-xs text-linen/75">
      <div class="flex flex-col md:flex-row items-center justify-between gap-2">
        <p>© {year} {site.legalName}</p>
        <p class="text-center">CNPJ {site.cnpj} · {site.address.full}</p>
      </div>
      <div class="flex flex-wrap justify-center md:justify-start gap-4 border-t border-linen/10 pt-3">
        <a href="/politica-de-privacidade/" class="hover:text-linen transition-colors">Política de Privacidade</a>
        <a href="/politica-de-qualidade/" class="hover:text-linen transition-colors">Política de Qualidade</a>
        <a href="/autor/joao-amaro/" class="hover:text-linen transition-colors">Autor: João Amaro</a>
      </div>
    </div>
  </div>
</footer>
