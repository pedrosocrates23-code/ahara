---
import { site } from '@/data/site';

const waNumber = '553198985678';
---

<!-- Chat popup -->
<div id="wa-chat" class="wa-chat" aria-hidden="true" role="dialog" aria-label="Chat WhatsApp Ahara">
  <div class="wa-chat__header">
    <div class="wa-chat__header-info">
      <div class="wa-chat__avatar">A</div>
      <div>
        <div class="wa-chat__name">Ahara</div>
        <div class="wa-chat__status">● online</div>
      </div>
    </div>
    <button id="wa-close" class="wa-chat__close" aria-label="Fechar chat" type="button">✕</button>
  </div>

  <div class="wa-chat__body">
    <div class="wa-chat__bubble">
      Olá! 👋 Para qual região você quer fazer seu pedido?
    </div>
  </div>

  <div class="wa-chat__footer">
    <input
      id="wa-input"
      type="text"
      class="wa-chat__input"
      placeholder="Digite sua região..."
      aria-label="Digite sua região"
      maxlength="80"
    />
    <button id="wa-send" class="wa-chat__send" type="button" aria-label="Enviar mensagem">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
      </svg>
    </button>
  </div>
</div>

<!-- Botão flutuante -->
<button
  id="wa-float"
  class="wa-float"
  type="button"
  aria-label="Abrir chat WhatsApp"
>
  <svg class="wa-float__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.12 1.535 5.856L0 24l6.336-1.511A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.822 9.822 0 01-5.003-1.366l-.36-.213-3.757.984 1.003-3.655-.234-.376A9.825 9.825 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.429 0 9.818 4.388 9.818 9.818 0 5.429-4.389 9.818-9.818 9.818z"/>
  </svg>
</button>

<style>
  /* ── Popup de chat ─────────────────────────────────── */
  .wa-chat {
    position: fixed;
    right: 1.25rem;
    bottom: 5.5rem;
    z-index: 61;
    width: 300px;
    background: #f4e7da;
    border: 2px solid #000;
    border-radius: 1rem;
    box-shadow: 4px 4px 0 0 #000;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(12px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .wa-chat--open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Header */
  .wa-chat__header {
    background: #0a6e3c;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    gap: 0.75rem;
  }

  .wa-chat__header-info {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .wa-chat__avatar {
    width: 38px;
    height: 38px;
    border-radius: 9999px;
    background: #fff;
    color: #0a6e3c;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #000;
    flex-shrink: 0;
  }

  .wa-chat__name {
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .wa-chat__status {
    font-size: 0.72rem;
    opacity: 0.85;
  }

  .wa-chat__close {
    background: none;
    border: none;
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    border-radius: 4px;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .wa-chat__close:hover { opacity: 0.75; }

  /* Corpo */
  .wa-chat__body {
    padding: 1rem;
  }

  .wa-chat__bubble {
    background: #fff;
    border: 2px solid #000;
    border-radius: 0 0.875rem 0.875rem 0.875rem;
    box-shadow: 2px 2px 0 0 #000;
    padding: 0.75rem 0.875rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #000;
    max-width: 90%;
  }

  /* Footer / input */
  .wa-chat__footer {
    display: flex;
    align-items: center;
    border-top: 2px solid #000;
    background: #fff;
  }

  .wa-chat__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    background: transparent;
    color: #000;
    font-family: inherit;
  }

  .wa-chat__input::placeholder { color: #666; }

  .wa-chat__send {
    background: #0a6e3c;
    color: #fff;
    border: none;
    border-left: 2px solid #000;
    padding: 0 0.875rem;
    height: 100%;
    min-height: 48px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .wa-chat__send:hover { background: #085c32; }

  /* ── Botão flutuante ───────────────────────────────── */
  .wa-float {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    width: 56px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #0a6e3c;
    color: #fff;
    border: 2px solid #000;
    border-radius: 9999px;
    box-shadow: 4px 4px 0 0 #000;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    animation: wa-bounce 3s ease-in-out infinite;
  }

  .wa-float:hover,
  .wa-float:focus-visible {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 #000;
    animation-play-state: paused;
  }

  .wa-float:focus-visible {
    outline: 3px solid #ffd800;
    outline-offset: 3px;
  }

  .wa-float__icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  @keyframes wa-bounce {
    0%, 92%, 100% { transform: translate(0, 0); }
    94%           { transform: translate(0, -4px); }
    96%           { transform: translate(0, 0); }
    98%           { transform: translate(0, -2px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float { animation: none; }
    .wa-chat  { transition: none; }
  }

  @media (max-width: 480px) {
    .wa-float {
      right: 1rem;
      bottom: 1rem;
      width: 52px;
      height: 52px;
    }

    .wa-chat {
      right: 1rem;
      bottom: 4.75rem;
      width: calc(100vw - 2rem);
    }
  }

  @media print {
    .wa-float,
    .wa-chat { display: none; }
  }
</style>

<script define:vars={{ waNumber }}>
  const STORAGE_KEY = 'ahara_wa_seen';

  const popup    = document.getElementById('wa-chat');
  const closeBtn = document.getElementById('wa-close');
  const sendBtn  = document.getElementById('wa-send');
  const floatBtn = document.getElementById('wa-float');
  const input    = document.getElementById('wa-input');

  function openPopup() {
    popup.classList.add('wa-chat--open');
    popup.setAttribute('aria-hidden', 'false');
    input.focus();
  }

  function closePopup() {
    popup.classList.remove('wa-chat--open');
    popup.setAttribute('aria-hidden', 'true');
    localStorage.setItem(STORAGE_KEY, '1');
  }

  function sendMessage() {
    const region = input.value.trim();
    const text = region
      ? `Olá! Gostaria de fazer um pedido para a região: ${region}`
      : 'Olá! Vim pelo site e gostaria de fazer um pedido.';
    window.open(
      `https://wa.me/${waNumber}?text=${encodeURIComponent(text)}`,
      '_blank',
      'noopener,noreferrer'
    );
    closePopup();
  }

  // Abre automaticamente apenas na primeira visita
  if (!localStorage.getItem(STORAGE_KEY)) {
    setTimeout(openPopup, 5000);
  }

  closeBtn.addEventListener('click', closePopup);

  floatBtn.addEventListener('click', () => {
    popup.classList.contains('wa-chat--open') ? closePopup() : openPopup();
  });

  sendBtn.addEventListener('click', sendMessage);

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage();
  });

  // Fecha com Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup.classList.contains('wa-chat--open')) closePopup();
  });
</script>
